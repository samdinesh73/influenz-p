datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  master_admin
  influencer
  brand_owner
}

enum CampaignStatus {
  draft
  published
  in_progress
  completed
  closed
}

enum ApplicationStatus {
  applied
  shortlisted
  hired
  rejected
}

enum InvitationStatus {
  sent
  accepted
  rejected
}

enum PaymentStatus {
  escrowed
  released
  refunded
}

// 1. Users Model
model User {
  id           String      @id @default(uuid()) @db.VarChar(36)
  role         Role
  email        String      @unique @db.VarChar(255)
  phone        String      @db.VarChar(20)
  passwordHash String      @map("password_hash") @db.VarChar(255)
  createdAt    DateTime    @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt    DateTime    @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)
  influencer   Influencer?
  brand        Brand?

  @@map("users")
}

// 2. Influencers Model
model Influencer {
  userId               String   @id @map("user_id") @db.VarChar(36)
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  username             String   @unique @db.VarChar(100)
  profileImage         String?  @map("profile_image") @db.Text
  bio                  String?  @db.Text
  country              String   @db.VarChar(100)
  state                String   @db.VarChar(100)
  district             String   @db.VarChar(100)
  city                 String?  @db.VarChar(100)
  categories           Json?
  languages            Json?
  followers            Int      @default(0)
  averageReach         Int      @default(0) @map("average_reach")
  engagementRate       Decimal  @default(0.00) @map("engagement_rate") @db.Decimal(5, 2)
  contentType          Json?    @map("content_type")
  instagramUsername    String?  @map("instagram_username") @db.VarChar(100)
  youtubeChannelUrl    String?  @map("youtube_channel_url") @db.Text
  facebookUrl          String?  @map("facebook_url") @db.Text
  linkedinUrl          String?  @map("linkedin_url") @db.Text
  twitterUsername      String?  @map("twitter_username") @db.VarChar(100)
  pinterestUrl         String?  @map("pinterest_url") @db.Text
  snapchatUsername     String?  @map("snapchat_username") @db.VarChar(100)
  websiteUrl           String?  @map("website_url") @db.Text
  pricePost            Decimal  @default(0.00) @map("price_post") @db.Decimal(10, 2)
  priceReel            Decimal  @default(0.00) @map("price_reel") @db.Decimal(10, 2)
  priceStory           Decimal  @default(0.00) @map("price_story") @db.Decimal(10, 2)
  availabilityCalendar Json?    @map("availability_calendar")
  gender               String?  @db.VarChar(50)
  age                  Int?
  verified             Boolean  @default(false)
  rating               Decimal  @default(0.00) @db.Decimal(3, 2)
  responseTime         String   @default("Within a few hours") @map("response_time") @db.VarChar(50)
  portfolio            Json?
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt            DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  @@map("influencers")
}

// 3. Brands Model
model Brand {
  userId                String   @id @map("user_id") @db.VarChar(36)
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName           String   @map("company_name") @db.VarChar(150)
  logo                  String?  @db.Text
  gst                   String?  @unique @db.VarChar(15)
  website               String?  @db.Text
  industry              String   @db.VarChar(100)
  country               String   @db.VarChar(100)
  state                 String   @db.VarChar(100)
  district              String   @db.VarChar(100)
  city                  String?  @db.VarChar(100)
  description           String?  @db.Text
  marketingBudget       Decimal  @default(0.00) @map("marketing_budget") @db.Decimal(15, 2)
  preferredCategories   Json?    @map("preferred_categories")
  targetAudience        String?  @map("target_audience") @db.Text
  verificationDocuments Json?    @map("verification_documents")
  verified              Boolean  @default(false)
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt             DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  @@map("brands")
}

// 4. Campaigns Model
model Campaign {
  id          String         @id @default(uuid()) @db.VarChar(36)
  brandId     String         @map("brand_id") @db.VarChar(36)
  title       String         @db.VarChar(255)
  description String         @db.Text
  budget      Decimal        @db.Decimal(12, 2)
  category    String         @db.VarChar(100)
  platform    String         @db.VarChar(100)
  deadline    DateTime       @db.Timestamp(0)
  duration    String?        @db.VarChar(100)
  status      CampaignStatus @default(published)
  createdAt   DateTime       @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt   DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  @@map("campaigns")
}

// 5. Applications Model
model Application {
  id           String            @id @default(uuid()) @db.VarChar(36)
  campaignId   String            @map("campaign_id") @db.VarChar(36)
  influencerId String            @map("influencer_id") @db.VarChar(36)
  status       ApplicationStatus @default(applied)
  proposal     String?           @db.Text
  createdAt    DateTime          @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt    DateTime          @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  @@unique([campaignId, influencerId], map: "unique_campaign_influencer_application")
  @@map("applications")
}

// 6. Invitations Model
model Invitation {
  id           String           @id @default(uuid()) @db.VarChar(36)
  brandId      String           @map("brand_id") @db.VarChar(36)
  influencerId String           @map("influencer_id") @db.VarChar(36)
  campaignId   String           @map("campaign_id") @db.VarChar(36)
  status       InvitationStatus @default(sent)
  createdAt    DateTime         @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt    DateTime         @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  @@unique([brandId, influencerId, campaignId], map: "unique_brand_influencer_campaign_invite")
  @@map("invitations")
}

// 7. Chats Model
model Chat {
  id          String   @id @default(uuid()) @db.VarChar(36)
  senderId    String   @map("sender_id") @db.VarChar(36)
  receiverId  String   @map("receiver_id") @db.VarChar(36)
  message     String   @db.Text
  attachments Json?
  isRead      Boolean  @default(false) @map("is_read")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(0)

  @@map("chats")
}

// 8. Payments Model
model Payment {
  id            String        @id @default(uuid()) @db.VarChar(36)
  campaignId    String        @map("campaign_id") @db.VarChar(36)
  brandId       String        @map("brand_id") @db.VarChar(36)
  influencerId  String        @map("influencer_id") @db.VarChar(36)
  amount        Decimal       @db.Decimal(12, 2)
  status        PaymentStatus @default(escrowed)
  transactionId String        @map("transaction_id") @db.VarChar(255)
  invoiceUrl    String?       @map("invoice_url") @db.Text
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt     DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  @@map("payments")
}

// 9. Reviews Model
model Review {
  id              String   @id @default(uuid()) @db.VarChar(36)
  reviewerId      String   @map("reviewer_id") @db.VarChar(36)
  targetId        String   @map("target_id") @db.VarChar(36)
  campaignId      String   @map("campaign_id") @db.VarChar(36)
  rating          Decimal  @db.Decimal(2, 1)
  communication   Decimal  @default(0.0) @db.Decimal(2, 1)
  paymentSpeed    Decimal  @default(0.0) @map("payment_speed") @db.Decimal(2, 1)
  professionalism Decimal  @default(0.0) @db.Decimal(2, 1)
  contentQuality  Decimal  @default(0.0) @map("content_quality") @db.Decimal(2, 1)
  comment         String?  @db.Text
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamp(0)

  @@unique([reviewerId, targetId, campaignId], map: "unique_reviewer_target_campaign")
  @@map("reviews")
}

// 10. Verification Codes Model
model VerificationCode {
  id        Int      @id @default(autoincrement())
  email     String   @db.VarChar(255)
  code      String   @db.VarChar(6)
  expiresAt DateTime @map("expires_at") @db.Timestamp(0)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(0)

  @@index([email], map: "idx_verification_codes_email")
  @@map("verification_codes")
}
